# Supabase – Project URL und Anon Key aus dem Supabase Dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Optionale Basis-URL (für Redirect nach Sign-Out)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Calendar API (für automatische Kalendereinträge bei Buchungen)
# Client ID & Secret: Google Cloud Console → APIs & Dienste → Anmeldedaten
GOOGLE_CLIENT_ID=deine-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-dein-client-secret
# Refresh Token: einmalig über /api/google/setup generieren (nach erstem Login)
GOOGLE_REFRESH_TOKEN=
# Kalender-ID (E-Mail des Kalenders)
GOOGLE_CALENDAR_ID=zollinger.baden@gmail.com
